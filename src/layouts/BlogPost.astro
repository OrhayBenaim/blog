---
import BaseLayout from './BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  tags: string[];
  minutesRead?: string;
  headings?: Heading[];
}

const { title, description, pubDate, updatedDate, tags, minutesRead, headings = [] } = Astro.props;
const tocHeadings = headings.filter(h => h.depth === 2);

function formatDate(date: Date): string {
  return date.toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });
}
---
<BaseLayout title={title} description={description}>
  <Header slot="header" />
  <article class="glass-article">
    <header class="post-header">
      <h1>{title}</h1>
      <div class="post-meta">
        <time datetime={pubDate.toISOString()}>{formatDate(pubDate)}</time>
        {updatedDate && (
          <span> · Updated <time datetime={updatedDate.toISOString()}>{formatDate(updatedDate)}</time></span>
        )}
        {minutesRead && <span> · {minutesRead}</span>}
      </div>
      {tags.length > 0 && (
        <div class="post-tags">
          {tags.map(tag => (
            <a href={`/blog/tags/${tag}/`} class="tag">#{tag}</a>
          ))}
        </div>
      )}
    </header>
    {tocHeadings.length > 2 && (
      <nav class="toc">
        <ul>
          {tocHeadings.map(h => (
            <li><a href={`#${h.slug}`}>{h.text}</a></li>
          ))}
        </ul>
      </nav>
    )}
    <div class="post-content">
      <slot />
    </div>
  </article>
  <Footer slot="footer" />
</BaseLayout>

<style>
  .glass-article {
    background: var(--bg-glass);
    backdrop-filter: blur(var(--glass-blur));
    -webkit-backdrop-filter: blur(var(--glass-blur));
    border: var(--glass-border);
    border-radius: var(--glass-radius);
    box-shadow: var(--glass-shadow);
    padding: 2.5rem;
    max-width: 720px;
    margin: 0 auto;
  }

  .post-header {
    margin-bottom: 2.5rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid rgba(42, 157, 143, 0.15);
  }

  .post-header h1 {
    margin-top: 0;
    font-size: 2.25rem;
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-weight: 800;
    color: var(--text);
  }

  .post-meta {
    color: var(--text-muted);
    font-size: 0.9rem;
    margin-top: 0.5rem;
  }

  .post-tags {
    display: flex;
    gap: 0.5rem;
    margin-top: 0.75rem;
    flex-wrap: wrap;
  }

  .tag {
    font-size: 0.8rem;
    color: var(--text-muted);
    background: rgba(42, 157, 143, 0.2);
    padding: 0.2rem 0.65rem;
    border-radius: 20px;
    border: 1px solid rgba(42, 157, 143, 0.35);
    transition: background var(--transition-fast), color var(--transition-fast);
  }

  .tag:hover {
    text-decoration: none;
    background: rgba(42, 157, 143, 0.3);
    color: var(--text);
  }

  .toc {
    margin-bottom: 2rem;
    padding: 1rem 1.25rem;
    background: var(--bg-glass-dark);
    border: var(--glass-border);
    border-radius: 12px;
  }

  .toc ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem 1rem;
  }

  .toc li {
    margin: 0;
  }

  .toc a {
    font-size: 0.85rem;
    color: var(--text-muted);
    transition: color var(--transition-fast);
  }

  .toc a:hover {
    color: var(--accent);
  }

  .post-content {
    font-size: 1.05rem;
  }

  .post-content :global(h2) {
    margin-top: 2.5rem;
  }

  .post-content :global(blockquote) {
    border-left: 3px solid var(--accent);
    padding-left: 1rem;
    color: var(--text-muted);
    margin: 1.5rem 0;
  }

  .post-content :global(pre) {
    background: var(--bg-glass-dark) !important;
    border: var(--glass-border);
    border-radius: 12px;
  }

  .post-content :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: 1.5rem 0;
    font-size: 0.95rem;
  }

  .post-content :global(th),
  .post-content :global(td) {
    padding: 0.6rem 0.75rem;
    border: 1px solid rgba(42, 157, 143, 0.3);
    text-align: left;
  }

  .post-content :global(th) {
    background: rgba(42, 157, 143, 0.1);
    font-weight: 600;
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.03em;
    color: var(--text-muted);
  }

  .post-content :global(tr:hover) {
    background: rgba(42, 157, 143, 0.05);
  }

  @media (max-width: 640px) {
    .glass-article {
      padding: 1.5rem;
      border-radius: 12px;
    }

    .post-content :global(table) {
      font-size: 0.85rem;
    }

    .post-content :global(th),
    .post-content :global(td) {
      padding: 0.4rem 0.5rem;
    }
  }
</style>
